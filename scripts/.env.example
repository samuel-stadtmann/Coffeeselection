# Coffee Selection — Skript-Konfiguration
# Kopiere diese Datei zu .env und fuelle die Werte aus.
# .env wird NICHT committet (siehe scripts/.gitignore).

# Supabase-Projekt-URL (aus Dashboard -> Settings -> API)
SUPABASE_URL=https://YOUR-PROJECT-REF.supabase.co

# service_role-Key (Settings -> API -> service_role secret)
# WARNUNG: Dieser Key umgeht RLS. NIE ins Frontend, NIE committen.
SUPABASE_SERVICE_ROLE_KEY=
