# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key

# Server-only — NIE auf Client geleakt. Wird für Cron-Jobs gebraucht.
# Holst du in Supabase → Project Settings → API → service_role secret
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# Vercel Cron Auth — generier ein zufälliges Token (z.B. `openssl rand -hex 32`).
# Vercel sendet automatisch `Authorization: Bearer ${CRON_SECRET}` an die Cron-Routes.
CRON_SECRET=your-random-cron-secret
