# Beispiel-Datei fuer lokales Testen mit `supabase functions serve`.
# Kopiere zu .env.local und trage echte Werte ein. NICHT committen.

OPENAI_API_KEY=sk-...

# Werden bei deployten Functions automatisch gesetzt — nur lokal noetig:
SUPABASE_URL=https://<project-ref>.supabase.co
SUPABASE_SERVICE_ROLE_KEY=<service_role_key>
