{
  "framework": "nextjs",
  "buildCommand": "npm run build",
  "devCommand": "npm run dev",
  "installCommand": "npm install",
  "crons": [
    {
      "path": "/api/cron/process-ratings",
      "schedule": "*/15 * * * *"
    },
    {
      "path": "/api/cron/check-reclassification",
      "schedule": "0 4 * * *"
    }
  ]
}
