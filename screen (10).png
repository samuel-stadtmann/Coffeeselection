<!DOCTYPE html>

<html class="light" lang="de"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<title>The Alpine Roast | Quiz Question 7</title>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&amp;family=Noto+Serif:wght@400;700&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script id="tailwind-config">
      tailwind.config = {
        darkMode: "class",
        theme: {
          extend: {
            colors: {
              "primary-fixed-dim": "#f0bba0",
              "surface-tint": "#7d553f",
              "on-background": "#1c1c19",
              "surface-container": "#f1ede8",
              "on-tertiary": "#ffffff",
              "surface-container-low": "#f7f3ee",
              "on-surface": "#1c1c19",
              "secondary-fixed-dim": "#d1c5ae",
              "tertiary-fixed-dim": "#f6be39",
              "outline": "#83746d",
              "on-secondary": "#ffffff",
              "tertiary": "#2a1d00",
              "on-tertiary-fixed-variant": "#5c4300",
              "on-tertiary-container": "#c79501",
              "on-primary-fixed-variant": "#623e2a",
              "error-container": "#ffdad6",
              "background": "#F9F5F0",
              "on-secondary-fixed": "#211b0c",
              "primary-fixed": "#ffdbca",
              "inverse-primary": "#f0bba0",
              "secondary-container": "#ebdec6",
              "on-primary-fixed": "#301404",
              "secondary-fixed": "#eee1c9",
              "surface-dim": "#ddd9d5",
              "surface-bright": "#F9F5F0",
              "inverse-on-surface": "#f4f0eb",
              "primary-container": "#4d2c19",
              "on-secondary-container": "#6b624f",
              "secondary": "#665d4b",
              "tertiary-container": "#453100",
              "on-tertiary-fixed": "#261a00",
              "surface": "#F9F5F0",
              "on-primary": "#ffffff",
              "tertiary-fixed": "#ffdfa0",
              "surface-variant": "#e6e2dd",
              "surface-container-high": "#ebe8e3",
              "on-error": "#ffffff",
              "on-surface-variant": "#51443e",
              "on-primary-container": "#c29279",
              "surface-container-lowest": "#ffffff",
              "inverse-surface": "#31302d",
              "primary": "#341706",
              "outline-variant": "#d5c3bb",
              "on-secondary-fixed-variant": "#4e4634",
              "on-error-container": "#93000a",
              "surface-container-highest": "#e6e2dd",
              "error": "#ba1a1a"
            },
            fontFamily: {
              "headline": ["Manrope"],
              "body": ["Noto Serif"],
              "label": ["Manrope"]
            },
            borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
          },
        },
      }
    </script>
<style>
        .material-symbols-outlined {
            font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
        }
        .editorial-shadow {
            box-shadow: 0 12px 40px rgba(77, 44, 25, 0.06);
        }
        .asymmetric-gradient {
            background: linear-gradient(135deg, #341706 0%, #4D2C19 100%);
        }
    </style>
</head>
<body class="bg-background text-on-surface font-body selection:bg-tertiary-fixed-dim selection:text-tertiary">
<!-- TopNavBar Unified with Screen_99 Style -->
<header class="fixed top-0 w-full z-50 bg-[#F9F5F0]/85 backdrop-blur-xl transition-all duration-300">
<nav class="flex justify-between items-center max-w-7xl mx-auto px-8 py-4 w-full">
<div class="flex items-center space-x-2">
<img alt="The Alpine Roast Logo" class="h-10 w-auto" src="https://lh3.googleusercontent.com/aida/ADBb0ugRAZCM5SrJlTMIN7z42waIBG1Z8FZXVL7I1jEs-qU7hjDq2N4ASNwSOMdu4FxkKIR6nAf7UHqU4I5npEIsgw4WyFaG_X0AvkIU8rg3pRcmeltA1SpP899XgzcISHOfRlrw_k_4ZYukIwg0aligXWGGqD038An-_vkqeA_ZHI7OHWQbsx0-j9e0tiNHSo5NxEhtY92n1Q3ru4hQzh2N8yqdZo5AVo_-H7JmcjukXCnPovA2aviwacHe25OXcmGwWbDZo5Eu1lxp"/>
<span class="text-2xl font-bold tracking-tight text-[#4D2C19] font-headline">The Alpine Roast</span>
</div>
<div class="hidden md:flex items-center space-x-10">
<a class="text-[#4D2C19] hover:text-[#D4A017] transition-colors font-label text-[10px] tracking-widest uppercase" href="#">Our Roasts</a>
<a class="text-[#4D2C19] hover:text-[#D4A017] transition-colors font-label text-[10px] tracking-widest uppercase" href="#">Subscriptions</a>
<a class="text-[#4D2C19] hover:text-[#D4A017] transition-colors font-label text-[10px] tracking-widest uppercase" href="#">Origins</a>
<a class="text-[#D4A017] border-b-2 border-[#D4A017] pb-1 font-label text-[10px] tracking-widest uppercase" href="#">The Ritual</a>
<a class="text-[#4D2C19] hover:text-[#D4A017] transition-colors font-label text-[10px] tracking-widest uppercase" href="#">Brewing Guides</a>
</div>
<div class="flex items-center space-x-6">
<span class="material-symbols-outlined text-primary text-2xl cursor-pointer hover:text-tertiary-fixed-dim transition-colors">shopping_bag</span>
<span class="material-symbols-outlined text-primary text-2xl cursor-pointer hover:text-tertiary-fixed-dim transition-colors">person</span>
<button class="bg-gradient-to-br from-primary to-primary-container text-white px-6 py-2 text-[10px] uppercase tracking-widest font-label font-bold rounded-lg shadow-sm hover:opacity-90 transition-all">
                Subscribe
            </button>
</div>
</nav>
</header>
<main class="min-h-screen flex flex-col items-center justify-center px-4 py-12 md:pt-32 md:pb-24">
<!-- Brand Identity (Progress only, Logo moved to Header) -->
<div class="mb-12 flex flex-col items-center">
<div class="flex items-center space-x-4">
<div class="h-px w-8 bg-outline-variant opacity-30"></div>
<span class="font-label text-xs tracking-widest text-on-surface-variant uppercase">Step 07 of 07</span>
<div class="h-px w-8 bg-outline-variant opacity-30"></div>
</div>
</div>
<!-- Quiz Container -->
<div class="w-full max-w-4xl grid grid-cols-1 md:grid-cols-12 gap-0 overflow-hidden bg-surface-container-low rounded-lg shadow-sm border border-outline-variant/10">
<!-- Question Content -->
<div class="md:col-span-7 p-8 md:p-16 flex flex-col justify-center">
<h1 class="font-headline text-3xl md:text-4xl font-bold text-primary tracking-tight mb-6 leading-tight">
                Wie oft brauchst du Nachschub?
            </h1>
<p class="text-on-surface-variant font-body mb-10 leading-relaxed max-w-md">
                Wähle dein bevorzugtes Lieferintervall. Wir rösten immer frisch vor dem Versand, damit dein Aroma-Erlebnis am Gipfel bleibt.
            </p>
<!-- Options Grid -->
<div class="space-y-4">
<button class="w-full group flex items-center justify-between p-5 bg-surface-container-lowest hover:bg-surface-container transition-colors text-left border-l-4 border-transparent hover:border-tertiary-fixed-dim">
<div class="flex items-center space-x-4">
<span class="material-symbols-outlined text-primary-container" data-icon="calendar_today">calendar_today</span>
<span class="font-headline font-semibold text-on-surface">Alle 2 Wochen</span>
</div>
<span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-tertiary-container" data-icon="arrow_forward">arrow_forward</span>
</button>
<button class="w-full group flex items-center justify-between p-5 bg-surface-container-lowest border-l-4 border-tertiary-fixed-dim text-left">
<div class="flex items-center space-x-4">
<span class="material-symbols-outlined text-primary-container" data-icon="event_repeat">event_repeat</span>
<span class="font-headline font-semibold text-on-surface">Monatlich</span>
</div>
<div class="flex items-center space-x-2">
<span class="font-label text-[10px] tracking-tighter bg-tertiary-fixed-dim/20 text-tertiary-container px-2 py-0.5 rounded">BELIEBTESTE WAHL</span>
<span class="material-symbols-outlined text-tertiary-container" data-icon="check_circle" style="font-variation-settings: 'FILL' 1;">check_circle</span>
</div>
</button>
<button class="w-full group flex items-center justify-between p-5 bg-surface-container-lowest hover:bg-surface-container transition-colors text-left border-l-4 border-transparent hover:border-tertiary-fixed-dim">
<div class="flex items-center space-x-4">
<span class="material-symbols-outlined text-primary-container" data-icon="calendar_month">calendar_month</span>
<span class="font-headline font-semibold text-on-surface">Alle 6 Wochen</span>
</div>
<span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-tertiary-container" data-icon="arrow_forward">arrow_forward</span>
</button>
<button class="w-full group flex items-center justify-between p-5 bg-surface-container-lowest hover:bg-surface-container transition-colors text-left border-l-4 border-transparent hover:border-tertiary-fixed-dim">
<div class="flex items-center space-x-4">
<span class="material-symbols-outlined text-primary-container" data-icon="shopping_basket">shopping_basket</span>
<span class="font-headline font-semibold text-on-surface">Nur einmalig</span>
</div>
<span class="material-symbols-outlined opacity-0 group-hover:opacity-100 transition-opacity text-tertiary-container" data-icon="arrow_forward">arrow_forward</span>
</button>
</div>
<!-- Footer Navigation -->
<div class="mt-12 flex items-center justify-between pt-8 border-t border-outline-variant/10">
<button class="flex items-center space-x-2 text-on-surface-variant hover:text-primary transition-colors">
<span class="material-symbols-outlined text-sm" data-icon="arrow_back">arrow_back</span>
<span class="font-label text-xs uppercase tracking-widest">Zurück</span>
</button>
<button class="asymmetric-gradient text-on-primary font-label text-xs uppercase tracking-[0.2em] px-10 py-4 shadow-lg hover:opacity-90 transition-all flex items-center space-x-3">
<span>Ergebnis anzeigen</span>
<span class="material-symbols-outlined text-sm" data-icon="analytics">analytics</span>
</button>
</div>
</div>
<!-- Asymmetric Sidebar Imagery -->
<div class="hidden md:block md:col-span-5 relative overflow-hidden bg-primary-container">
<img alt="Artisanal Coffee Ritual" class="absolute inset-0 w-full h-full object-cover opacity-60 mix-blend-multiply" src="https://lh3.googleusercontent.com/aida-public/AB6AXuBldOD7F8eFqcBZT-MLCuDgvezh7xSuDId5D_8pJ6CQur77dX5B2mXcROngRvK3ComZea5QT5Z-baSAwkACjQ3ZhqCafYLMREDoHbY1J7zX1-5eqMexaABcq55029D43KEKwLUcts3p6-DqyJzAJBNHMTwureoTGje6Yl3vRo6ZTByzirvFsmci-87s0zRy3NOrKKtOwORRWrhunt3tm41xVjc52-wsvxJVWy5Rw3Pi4ydtRFIa9KhCajTj1999OHbS1qZFpawN1g"/>
<div class="absolute inset-0 p-12 flex flex-col justify-end text-on-primary">
<div class="space-y-6">
<div class="h-px w-12 bg-tertiary-fixed-dim"></div>
<h3 class="font-headline text-2xl font-bold leading-tight">Frische, die man schmeckt.</h3>
<p class="font-body text-sm text-surface-container opacity-80 leading-relaxed italic">
                        "Unser Abo-Modell passt sich deinem Lebensrhythmus an. Keine Mindestlaufzeit, volle Flexibilität."
                    </p>
<!-- Origin Gauge Component -->
<div class="space-y-2 pt-4">
<div class="flex justify-between font-label text-[10px] tracking-widest text-on-primary/60 uppercase">
<span>Flexibilität</span>
<span>Maximale Kontrolle</span>
</div>
<div class="h-1 w-full bg-on-primary/10 rounded-full overflow-hidden">
<div class="h-full w-[85%] bg-tertiary-fixed-dim"></div>
</div>
</div>
</div>
</div>
</div>
</div>
<!-- Footer -->
<footer class="mt-24 w-full max-w-7xl px-8 py-12 border-t border-outline-variant/10 text-center">
<p class="font-label text-[10px] uppercase tracking-[0.3em] text-on-surface-variant/50">
            © 2024 The Alpine Roast. Crafted for the Editorial Sommelier.
        </p>
</footer>
</main>
</body></html>