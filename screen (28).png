<!DOCTYPE html>

<html class="light" lang="en"><head>
<meta charset="utf-8"/>
<meta content="width=device-width, initial-scale=1.0" name="viewport"/>
<link href="https://fonts.googleapis.com/css2?family=Manrope:wght@400;600;700;800&amp;family=Noto+Serif:ital,wght@0,400;1,400&amp;family=Montserrat:wght@400;700;900&amp;display=swap" rel="stylesheet"/>
<link href="https://fonts.googleapis.com/css2?family=Material+Symbols+Outlined:wght,FILL@100..700,0..1&amp;display=swap" rel="stylesheet"/>
<script src="https://cdn.tailwindcss.com?plugins=forms,container-queries"></script>
<script id="tailwind-config">
    tailwind.config = {
      darkMode: "class",
      theme: {
        extend: {
          colors: {
            "inverse-surface": "#31302d",
            "on-error-container": "#93000a",
            "surface-container-high": "#ebe8e3",
            "secondary-container": "#ebdec6",
            "primary": "#341706",
            "on-secondary-fixed-variant": "#4e4634",
            "on-primary-container": "#c29279",
            "on-tertiary-fixed": "#261a00",
            "on-background": "#1c1c19",
            "primary-fixed-dim": "#f0bba0",
            "on-surface": "#1c1c19",
            "inverse-on-surface": "#f4f0eb",
            "on-secondary-fixed": "#211b0c",
            "surface-variant": "#e6e2dd",
            "error": "#ba1a1a",
            "surface-container": "#f1ede8",
            "primary-container": "#4d2c19",
            "on-tertiary-fixed-variant": "#5c4300",
            "surface-dim": "#ddd9d5",
            "primary-fixed": "#ffdbca",
            "outline-variant": "#d5c3bb",
            "secondary-fixed-dim": "#d1c5ae",
            "on-tertiary-container": "#c79501",
            "tertiary-fixed-dim": "#f6be39",
            "on-primary": "#ffffff",
            "surface-bright": "#fdf9f4",
            "on-secondary": "#ffffff",
            "surface": "#fdf9f4",
            "outline": "#83746d",
            "on-error": "#ffffff",
            "error-container": "#ffdad6",
            "on-primary-fixed-variant": "#623e2a",
            "surface-container-lowest": "#ffffff",
            "tertiary": "#2a1d00",
            "on-tertiary": "#ffffff",
            "surface-container-highest": "#e6e2dd",
            "on-secondary-container": "#6b624f",
            "surface-container-low": "#f7f3ee",
            "tertiary-fixed": "#ffdfa0",
            "background": "#F9F5F0",
            "secondary-fixed": "#eee1c9",
            "on-primary-fixed": "#301404",
            "secondary": "#665d4b",
            "tertiary-container": "#453100",
            "surface-tint": "#7d553f",
            "inverse-primary": "#f0bba0",
            "on-surface-variant": "#51443e"
          },
          fontFamily: {
            "headline": ["Manrope"],
            "body": ["Noto Serif"],
            "label": ["Montserrat", "sans-serif"]
          },
          borderRadius: {"DEFAULT": "0.125rem", "lg": "0.25rem", "xl": "0.5rem", "full": "0.75rem"},
        },
      },
    }
  </script>
<style>
    .material-symbols-outlined {
      font-variation-settings: 'FILL' 0, 'wght' 400, 'GRAD' 0, 'opsz' 24;
    }
    input:focus {
      outline: none !important;
      box-shadow: none !important;
      border-bottom-color: #341706 !important;
    }
    .custom-scrollbar::-webkit-scrollbar {
      width: 4px;
    }
    .custom-scrollbar::-webkit-scrollbar-track {
      background: #f7f3ee;
    }
    .custom-scrollbar::-webkit-scrollbar-thumb {
      background: #d5c3bb;
    }
  </style>
</head>
<body class="bg-[#F9F5F0] text-on-background font-body antialiased">
<!-- TopNavBar (Unified style from SCREEN_99) -->
<header class="fixed top-0 w-full z-50 bg-[#F9F5F0]/85 backdrop-blur-xl border-b border-outline-variant/5 transition-all duration-300">
<nav class="flex justify-between items-center max-w-7xl mx-auto px-8 py-4 w-full">
<div class="flex items-center space-x-2">
<img alt="The Alpine Roast Logo" class="h-10 w-auto" src="https://lh3.googleusercontent.com/aida/ADBb0ugRAZCM5SrJlTMIN7z42waIBG1Z8FZXVL7I1jEs-qU7hjDq2N4ASNwSOMdu4FxkKIR6nAf7UHqU4I5npEIsgw4WyFaG_X0AvkIU8rg3pRcmeltA1SpP899XgzcISHOfRlrw_k_4ZYukIwg0aligXWGGqD038An-_vkqeA_ZHI7OHWQbsx0-j9e0tiNHSo5NxEhtY92n1Q3ru4hQzh2N8yqdZo5AVo_-H7JmcjukXCnPovA2aviwacHe25OXcmGwWbDZo5Eu1lxp"/>
<span class="text-2xl font-bold tracking-tight text-[#4D2C19] font-headline">The Alpine Roast</span>
</div>
<div class="hidden md:flex items-center space-x-10">
<a class="text-[#4D2C19] hover:text-[#D4A017] transition-colors font-label text-[10px] tracking-widest uppercase" href="#">Our Roasts</a>
<a class="text-[#4D2C19] hover:text-[#D4A017] transition-colors font-label text-[10px] tracking-widest uppercase" href="#">Subscriptions</a>
<a class="text-[#4D2C19] hover:text-[#D4A017] transition-colors font-label text-[10px] tracking-widest uppercase" href="#">Origins</a>
<a class="text-[#4D2C19] hover:text-[#D4A017] transition-colors font-label text-[10px] tracking-widest uppercase" href="#">The Ritual</a>
<a class="text-[#4D2C19] hover:text-[#D4A017] transition-colors font-label text-[10px] tracking-widest uppercase" href="#">Brewing Guides</a>
</div>
<div class="flex items-center space-x-6">
<span class="material-symbols-outlined text-primary text-2xl cursor-pointer hover:text-tertiary-fixed-dim transition-colors">shopping_bag</span>
<span class="material-symbols-outlined text-primary text-2xl cursor-pointer hover:text-tertiary-fixed-dim transition-colors">person</span>
<a class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant hover:text-primary transition-colors duration-300 flex items-center gap-2" href="/">
<span class="material-symbols-outlined text-sm">close</span>
          Exit Checkout
        </a>
</div>
</nav>
</header>
<main class="pt-32 pb-24 px-8 md:px-12 max-w-[1440px] mx-auto min-h-screen">
<!-- Progress Stepper -->
<nav class="mb-20 max-w-3xl mx-auto md:mx-0">
<div class="flex items-center gap-8 md:gap-16">
<div class="flex items-center gap-4 group">
<span class="font-headline font-extrabold text-2xl text-primary border-b-2 border-primary pb-1">01</span>
<span class="font-headline font-bold uppercase tracking-widest text-[11px] text-primary">Shipping</span>
</div>
<div class="h-[1px] w-8 md:w-16 bg-outline-variant/30"></div>
<div class="flex items-center gap-4 opacity-40">
<span class="font-headline font-extrabold text-2xl text-on-surface-variant">02</span>
<span class="font-headline font-bold uppercase tracking-widest text-[11px] text-on-surface-variant">Payment</span>
</div>
<div class="h-[1px] w-8 md:w-16 bg-outline-variant/30"></div>
<div class="flex items-center gap-4 opacity-40">
<span class="font-headline font-extrabold text-2xl text-on-surface-variant">03</span>
<span class="font-headline font-bold uppercase tracking-widest text-[11px] text-on-surface-variant">Review</span>
</div>
</div>
</nav>
<div class="grid grid-cols-1 lg:grid-cols-12 gap-16 xl:gap-24 items-start">
<!-- Checkout Form Canvas -->
<section class="lg:col-span-7 xl:col-span-8">
<h1 class="font-headline font-bold text-4xl md:text-5xl tracking-tight text-primary mb-12">Shipping Information</h1>
<form class="space-y-12">
<!-- Personal Info -->
<div class="grid grid-cols-1 md:grid-cols-2 gap-x-12 gap-y-10">
<div class="flex flex-col gap-2">
<label class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">First Name</label>
<input class="bg-transparent border-t-0 border-x-0 border-b-2 border-outline-variant/20 py-3 text-on-surface font-body placeholder:text-outline-variant transition-all" placeholder="Hans" type="text"/>
</div>
<div class="flex flex-col gap-2">
<label class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Last Name</label>
<input class="bg-transparent border-t-0 border-x-0 border-b-2 border-outline-variant/20 py-3 text-on-surface font-body placeholder:text-outline-variant transition-all" placeholder="Müller" type="text"/>
</div>
<div class="flex flex-col gap-2 md:col-span-2">
<label class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Email Address</label>
<input class="bg-transparent border-t-0 border-x-0 border-b-2 border-outline-variant/20 py-3 text-on-surface font-body placeholder:text-outline-variant transition-all" placeholder="hans.mueller@zurich.ch" type="email"/>
</div>
</div>
<!-- Address -->
<div class="grid grid-cols-1 md:grid-cols-12 gap-x-12 gap-y-10">
<div class="flex flex-col gap-2 md:col-span-12">
<label class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Street &amp; House Number</label>
<input class="bg-transparent border-t-0 border-x-0 border-b-2 border-outline-variant/20 py-3 text-on-surface font-body placeholder:text-outline-variant transition-all" placeholder="Bahnhofstrasse 12" type="text"/>
</div>
<div class="flex flex-col gap-2 md:col-span-4">
<label class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Postal Code</label>
<input class="bg-transparent border-t-0 border-x-0 border-b-2 border-outline-variant/20 py-3 text-on-surface font-body placeholder:text-outline-variant transition-all" placeholder="8001" type="text"/>
</div>
<div class="flex flex-col gap-2 md:col-span-8">
<label class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">City</label>
<input class="bg-transparent border-t-0 border-x-0 border-b-2 border-outline-variant/20 py-3 text-on-surface font-body placeholder:text-outline-variant transition-all" placeholder="Zürich" type="text"/>
</div>
<div class="flex flex-col gap-2 md:col-span-12">
<label class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Country</label>
<div class="relative">
<input class="w-full bg-transparent border-t-0 border-x-0 border-b-2 border-outline-variant/20 py-3 text-on-surface font-body transition-all" readonly="" type="text" value="Switzerland"/>
<span class="material-symbols-outlined absolute right-0 top-3 text-outline-variant">lock</span>
</div>
</div>
</div>
<div class="pt-8">
<button class="bg-gradient-to-br from-primary to-primary-container text-on-primary font-headline font-bold uppercase tracking-widest text-xs px-12 py-5 hover:opacity-90 transition-opacity" type="submit">
              Continue to Payment
            </button>
</div>
</form>
</section>
<!-- Order Summary Sidebar -->
<aside class="lg:col-span-5 xl:col-span-4 sticky top-32">
<div class="bg-surface-container-low p-10 space-y-8">
<div class="flex items-center justify-between border-b border-outline-variant/10 pb-6">
<h2 class="font-headline font-bold text-xl tracking-tight text-primary">Order Summary</h2>
<span class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">2 Items</span>
</div>
<!-- Items List -->
<div class="space-y-6 max-h-64 overflow-y-auto custom-scrollbar pr-4">
<div class="flex gap-6 items-center">
<div class="h-20 w-20 bg-surface-container shrink-0 flex items-center justify-center">
<img alt="The Eiger Roast" class="h-16 w-16 object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuCAGfIWir3qbfweVmyKLoOSXZGe2S2JZMiAKIe9tWOdH7r0IELILIwRCfDOtDEfpReGoegG7gk9H2Z-nhau8j3muug7HUwZFoBt-U2b24Rk7BuHUL4UDlgcQFXHqZSPr4uLdizKXVQhWyjzbDVApLkBDUT3LlVvNW9tPxOQpTB5wN2HTLtPmFVmU8zx31oHcwN-OjNLJ40hEZlVhT8gayzzCQd7DqNL6KEsovvFTzMn4P8uVn1w1PzQxZyUOTYO1AWNTqJsAtD-yQ"/>
</div>
<div class="flex-1">
<h3 class="font-headline font-bold text-sm text-primary uppercase tracking-wide">The Eiger Roast</h3>
<p class="font-body italic text-xs text-on-surface-variant">500g, Whole Bean</p>
<div class="flex justify-between items-end mt-2">
<span class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Qty: 1</span>
<span class="font-headline font-bold text-sm text-primary">CHF 32.00</span>
</div>
</div>
</div>
<div class="flex gap-6 items-center">
<div class="h-20 w-20 bg-surface-container shrink-0 flex items-center justify-center">
<img alt="Bernese Gold" class="h-16 w-16 object-cover" src="https://lh3.googleusercontent.com/aida-public/AB6AXuDvCx4RRgPWVlupTe6qFevDj8tLox8HQCxxE0sxc8mi7ekpUxWUwzVXrMj7cW0dPAUqz0ETiE3SgybLXfw_0Whpx4k3dl8ClbwALPafkh9sZL-NR02AcAmC_EK2RZKCuiamt5k1aGgV4FlkVqWGb2JJ08AcxEmWCClwk_-l20lBFbPz7ayhJOgEfTU44sP4nluSAjueaLudPXWl6opEiaBvZyK9Fv-hOwoTAMFKKT4E2QS-CWIpOfnat-Lg3x-ryP9heeHjKMaPkg"/>
</div>
<div class="flex-1">
<h3 class="font-headline font-bold text-sm text-primary uppercase tracking-wide">Bernese Gold</h3>
<p class="font-body italic text-xs text-on-surface-variant">250g, AeroPress</p>
<div class="flex justify-between items-end mt-2">
<span class="font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">Qty: 1</span>
<span class="font-headline font-bold text-sm text-primary">CHF 18.00</span>
</div>
</div>
</div>
</div>
<!-- Subscription Toggle -->
<div class="bg-surface-container-highest/30 p-6 space-y-4 border border-outline-variant/10">
<div class="flex items-center justify-between">
<div class="flex items-center gap-3">
<span class="material-symbols-outlined text-tertiary-fixed-dim" data-weight="fill">sync</span>
<span class="font-headline font-bold text-[11px] uppercase tracking-widest text-primary">Alpine Fresh Plan</span>
</div>
<div class="relative inline-block w-8 h-4 align-middle select-none transition duration-200 ease-in">
<input checked="" class="toggle-checkbox absolute block w-4 h-4 rounded-full bg-white border-2 border-outline-variant appearance-none cursor-pointer checked:right-0 right-4 transition-all duration-300 checked:bg-tertiary-fixed-dim checked:border-tertiary-fixed-dim" id="toggle" name="toggle" type="checkbox"/>
<label class="toggle-label block overflow-hidden h-4 rounded-full bg-outline-variant/20 cursor-pointer" for="toggle"></label>
</div>
</div>
<p class="font-body text-xs text-on-surface-variant">Deliver every 4 weeks and <span class="font-bold text-primary italic">Save CHF 4</span> on this order.</p>
</div>
<!-- Totals -->
<div class="space-y-4 pt-4">
<div class="flex justify-between font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">
<span>Subtotal</span>
<span>CHF 50.00</span>
</div>
<div class="flex justify-between font-label text-[10px] font-bold uppercase tracking-widest text-on-surface-variant">
<span>Shipping (Swiss Post)</span>
<span>CHF 0.00</span>
</div>
<div class="flex justify-between font-label text-[10px] font-bold uppercase tracking-widest text-tertiary-fixed-dim">
<span>Subscription Discount</span>
<span>- CHF 4.00</span>
</div>
<div class="flex justify-between items-end pt-4 border-t border-outline-variant/10">
<span class="font-headline font-bold text-sm uppercase tracking-widest text-primary">Total</span>
<div class="text-right">
<p class="font-headline font-extrabold text-2xl text-primary leading-none">CHF 46.00</p>
<p class="font-label text-[9px] uppercase tracking-widest text-on-surface-variant mt-1">Incl. 2.5% MwSt.</p>
</div>
</div>
</div>
</div>
</aside>
</div>
</main>
<footer class="w-full py-20 bg-[#F9F5F0] mt-12 border-t border-outline-variant/10">
<div class="flex flex-col items-center gap-8 px-12 text-center max-w-[1920px] mx-auto">
<div class="font-headline font-bold text-lg text-primary tracking-tighter">The Alpine Roast</div>
<nav class="flex flex-wrap justify-center gap-8">
<a class="font-body italic text-sm text-on-primary-fixed-variant/60 hover:text-primary transition-all" href="#">Sustainability</a>
<a class="font-body italic text-sm text-on-primary-fixed-variant/60 hover:text-primary transition-all" href="#">Newsletter</a>
<a class="font-body italic text-sm text-on-primary-fixed-variant/60 hover:text-primary transition-all" href="#">Privacy Policy</a>
<a class="font-body italic text-sm text-on-primary-fixed-variant/60 hover:text-primary transition-all" href="#">Terms of Service</a>
</nav>
<p class="font-body italic text-sm text-on-surface-variant/60">© 2024 The Alpine Roast. Swiss Precision in Every Bean.</p>
</div>
</footer>
</body></html>